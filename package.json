{
  "name": "temp-mail",
  "version": "0.1.0",
  "private": true,
  "description": "Personal catch-all temporary mailbox on Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "wrangler deploy --dry-run",
    "db:init:local": "wrangler d1 execute temp_mail --local --file=./schema/init.sql"
  },
  "keywords": [
    "cloudflare-workers",
    "d1",
    "temporary-email",
    "email-routing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "postal-mime": "^2.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}
